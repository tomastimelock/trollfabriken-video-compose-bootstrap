{
  "tvcs": "1.0",
  "template": {
    "id": "esports_match_overlay",
    "name": "Esports Match Overlay",
    "category": "entertainment",
    "tags": [
      "entertainment",
      "esports",
      "gaming",
      "scoreboard",
      "overlay",
      "HUD",
      "hologram",
      "broadcast"
    ],
    "description": "Esports broadcast-style match result overlay: video background with hologram shape-fx frame, team names, score, round/map info and K/D/A stats. Dark neon HUD aesthetic.",
    "preview_thumbnail": "previews/thumbnails/esports_match_overlay.jpg",
    "preview_full": "previews/full/esports_match_overlay.jpg",
    "author": "Trollfabriken",
    "version": "1.0",
    "variables": [
      {
        "name": "video_source",
        "type": "video_path",
        "label": "Match footage / background",
        "required": true
      },
      {
        "name": "team_a",
        "type": "string",
        "label": "Team A name",
        "required": true,
        "default": "TEAM ALPHA"
      },
      {
        "name": "team_b",
        "type": "string",
        "label": "Team B name",
        "required": true,
        "default": "TEAM BETA"
      },
      {
        "name": "score_a",
        "type": "number",
        "label": "Team A score",
        "required": true,
        "default": 16
      },
      {
        "name": "score_b",
        "type": "number",
        "label": "Team B score",
        "required": true,
        "default": 9
      },
      {
        "name": "map_name",
        "type": "string",
        "label": "Map / game name",
        "required": false,
        "default": "Mirage"
      },
      {
        "name": "round_info",
        "type": "string",
        "label": "Round / series info",
        "required": false,
        "default": "Round 2 of 3  ·  Semi-final"
      },
      {
        "name": "stat_line",
        "type": "string",
        "label": "MVP or key stat line",
        "required": false,
        "default": "MVP: Player1  ·  K/D 28/8  ·  ADR 98.4"
      },
      {
        "name": "accent_color",
        "type": "color",
        "label": "HUD accent colour",
        "required": false,
        "default": "#00ffcc"
      },
      {
        "name": "clip_duration",
        "type": "duration",
        "label": "Clip duration (s)",
        "required": false,
        "default": 12.0
      }
    ]
  },
  "output": {
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "path": "./output/esports_match_overlay.mp4"
  },
  "theme": {
    "background": "#000000",
    "text_color": "#ffffff"
  },
  "segments": [
    {
      "id": "match",
      "type": "video",
      "source": "{{video_source}}",
      "duration": "{{clip_duration}}",
      "overlays": [
        {
          "type": "text",
          "text": "{{team_a}}",
          "effect": "slide_right_text",
          "position": "top-left",
          "color": "#ffffff",
          "timing": {
            "start": 0.5
          }
        },
        {
          "type": "text",
          "text": "{{score_a}}  :  {{score_b}}",
          "effect": "drop_in",
          "position": "top",
          "color": "{{accent_color}}",
          "timing": {
            "start": 0.8
          }
        },
        {
          "type": "text",
          "text": "{{team_b}}",
          "effect": "slide_left_text",
          "position": "top-right",
          "color": "#ffffff",
          "timing": {
            "start": 0.5
          }
        },
        {
          "type": "text",
          "text": "{{map_name}}",
          "effect": "fade_in",
          "position": "bottom",
          "color": "{{accent_color}}",
          "timing": {
            "start": 1.0
          }
        },
        {
          "type": "text",
          "text": "{{round_info}}",
          "effect": "fade_in",
          "position": "bottom",
          "color": "#aaaaaa",
          "timing": {
            "start": 1.5
          }
        },
        {
          "type": "text",
          "text": "{{stat_line}}",
          "effect": "slide_up_text",
          "position": "bottom",
          "color": "#ffffff",
          "timing": {
            "start": 4.0
          }
        }
      ]
    }
  ]
}