{
  "tvcs": "1.0",
  "template": {
    "id": "explainer_pros_cons",
    "name": "Explainer — Pros vs Cons",
    "category": "explainer",
    "tags": [
      "explainer",
      "pros",
      "cons",
      "comparison",
      "decision",
      "review",
      "education"
    ],
    "description": "Animated pros vs cons breakdown: title card, left column (pros in green) and right column (cons in red) stagger in simultaneously, summary verdict outro.",
    "preview_thumbnail": "previews/thumbnails/explainer_pros_cons.jpg",
    "preview_full": "previews/full/explainer_pros_cons.jpg",
    "author": "Trollfabriken",
    "version": "1.0",
    "variables": [
      {
        "name": "subject",
        "type": "string",
        "label": "Subject being evaluated",
        "required": true,
        "default": "Working from home"
      },
      {
        "name": "pro_1",
        "type": "string",
        "label": "Pro 1",
        "required": true,
        "default": "Flexible schedule"
      },
      {
        "name": "pro_2",
        "type": "string",
        "label": "Pro 2",
        "required": false,
        "default": "No commute"
      },
      {
        "name": "pro_3",
        "type": "string",
        "label": "Pro 3",
        "required": false,
        "default": "Better work-life balance"
      },
      {
        "name": "con_1",
        "type": "string",
        "label": "Con 1",
        "required": true,
        "default": "Harder to collaborate"
      },
      {
        "name": "con_2",
        "type": "string",
        "label": "Con 2",
        "required": false,
        "default": "Distractions at home"
      },
      {
        "name": "con_3",
        "type": "string",
        "label": "Con 3",
        "required": false,
        "default": "Risk of isolation"
      },
      {
        "name": "verdict",
        "type": "string",
        "label": "Verdict / summary",
        "required": false,
        "default": "It depends on your role."
      },
      {
        "name": "pro_color",
        "type": "color",
        "label": "Pros colour",
        "required": false,
        "default": "#22c55e"
      },
      {
        "name": "con_color",
        "type": "color",
        "label": "Cons colour",
        "required": false,
        "default": "#ef4444"
      },
      {
        "name": "bg_color",
        "type": "color",
        "label": "Background colour",
        "required": false,
        "default": "#0f1923"
      }
    ]
  },
  "output": {
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "path": "./output/explainer_pros_cons.mp4"
  },
  "theme": {
    "background": "{{bg_color}}",
    "text_color": "#ffffff"
  },
  "segments": [
    {
      "id": "title",
      "type": "blank",
      "duration": 2.5,
      "color": "{{bg_color}}",
      "overlays": [
        {
          "type": "text",
          "text": "{{subject}}",
          "effect": "drop_in",
          "position": "center",
          "color": "#ffffff",
          "timing": {
            "start": 0.5
          }
        }
      ]
    },
    {
      "id": "comparison",
      "type": "shape",
      "duration": 10.0,
      "effect": "stagger_reveal",
      "config": {
        "color": "#444444"
      },
      "overlays": [
        {
          "type": "text",
          "text": "Pros",
          "effect": "fade_in",
          "position": "top-left",
          "color": "{{pro_color}}",
          "timing": {
            "start": 0.3
          }
        },
        {
          "type": "text",
          "text": "Cons",
          "effect": "fade_in",
          "position": "top-right",
          "color": "{{con_color}}",
          "timing": {
            "start": 0.3
          }
        },
        {
          "type": "text",
          "text": "{{pro_1}}",
          "effect": "slide_right_text",
          "position": "center",
          "color": "{{pro_color}}",
          "timing": {
            "start": 0.8,
            "end": 4.0
          }
        },
        {
          "type": "text",
          "text": "{{con_1}}",
          "effect": "slide_left_text",
          "position": "center",
          "color": "{{con_color}}",
          "timing": {
            "start": 0.8,
            "end": 4.0
          }
        },
        {
          "type": "text",
          "text": "{{pro_2}}",
          "effect": "slide_right_text",
          "position": "center",
          "color": "{{pro_color}}",
          "timing": {
            "start": 3.5,
            "end": 7.0
          }
        },
        {
          "type": "text",
          "text": "{{con_2}}",
          "effect": "slide_left_text",
          "position": "center",
          "color": "{{con_color}}",
          "timing": {
            "start": 3.5,
            "end": 7.0
          }
        },
        {
          "type": "text",
          "text": "{{pro_3}}",
          "effect": "slide_right_text",
          "position": "center",
          "color": "{{pro_color}}",
          "timing": {
            "start": 7.0
          }
        },
        {
          "type": "text",
          "text": "{{con_3}}",
          "effect": "slide_left_text",
          "position": "center",
          "color": "{{con_color}}",
          "timing": {
            "start": 7.0
          }
        }
      ]
    },
    {
      "id": "verdict",
      "type": "blank",
      "duration": 3.0,
      "color": "{{bg_color}}",
      "overlays": [
        {
          "type": "text",
          "text": "{{verdict}}",
          "effect": "fade_in",
          "position": "center",
          "color": "#ffffff",
          "timing": {
            "start": 0.6
          }
        }
      ]
    }
  ],
  "transitions": {
    "default": {
      "type": "dissolve_ii",
      "duration": 0.5
    }
  }
}