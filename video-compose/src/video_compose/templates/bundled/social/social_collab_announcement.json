{
  "tvcs": "1.0",
  "template": {
    "id": "social_collab_announcement",
    "name": "Collaboration Announcement",
    "category": "social",
    "tags": ["social", "collab", "collaboration", "announcement", "creator", "brand", "partnership"],
    "description": "Creator or brand collaboration announcement: first creator photo reveal, neon connector card, second creator photo reveal, joint event/project outro.",
    "preview_thumbnail": "previews/thumbnails/social_collab_announcement.jpg",
    "preview_full": "previews/full/social_collab_announcement.jpg",
    "author": "Trollfabriken",
    "version": "1.0",
    "variables": [
      {"name": "creator_1_name",  "type": "string",     "label": "Creator / brand 1 name", "required": true,  "default": "Creator One"},
      {"name": "creator_2_name",  "type": "string",     "label": "Creator / brand 2 name", "required": true,  "default": "Creator Two"},
      {"name": "photo_1",         "type": "image_path", "label": "Photo / logo 1",          "required": true},
      {"name": "photo_2",         "type": "image_path", "label": "Photo / logo 2",          "required": true},
      {"name": "collab_title",    "type": "string",     "label": "Project / event title",   "required": false, "default": "Coming together"},
      {"name": "event_date",      "type": "string",     "label": "Date or launch info",     "required": false, "default": "Available now"},
      {"name": "accent_color",    "type": "color",      "label": "Accent colour",           "required": false, "default": "#ff6b35"},
      {"name": "bg_color",        "type": "color",      "label": "Background colour",       "required": false, "default": "#0a0a0a"}
    ]
  },
  "output": {"width": 1920, "height": 1080, "fps": 30, "path": "./output/social_collab_announcement.mp4"},
  "theme": {"background": "{{bg_color}}", "text_color": "#ffffff"},
  "segments": [
    {
      "id": "creator_1",
      "type": "still",
      "duration": 3.5,
      "source": "{{photo_1}}",
      "motion": "zoom_in",
      "overlays": [
        {"type": "text", "text": "{{creator_1_name}}", "effect": "slide_right", "position": "bottom", "color": "#ffffff", "timing": {"start": 0.8}}
      ]
    },
    {
      "id": "connector",
      "type": "shape",
      "duration": 2.5,
      "effect": "neon_glow",
      "config": {"color": "{{accent_color}}"},
      "overlays": [
        {"type": "text", "text": "×",                 "effect": "zoom_in",  "position": "center", "color": "{{accent_color}}", "timing": {"start": 0.3}},
        {"type": "text", "text": "{{collab_title}}", "effect": "fade_in",  "position": "bottom", "color": "#ffffff",          "timing": {"start": 0.9}}
      ]
    },
    {
      "id": "creator_2",
      "type": "still",
      "duration": 3.5,
      "source": "{{photo_2}}",
      "motion": "zoom_in",
      "overlays": [
        {"type": "text", "text": "{{creator_2_name}}", "effect": "slide_left", "position": "bottom", "color": "#ffffff", "timing": {"start": 0.8}}
      ]
    },
    {
      "id": "outro",
      "type": "blank",
      "duration": 3.0,
      "color": "{{bg_color}}",
      "overlays": [
        {"type": "text", "text": "{{creator_1_name}}  ×  {{creator_2_name}}", "effect": "fade_in",  "position": "center", "color": "#ffffff",          "timing": {"start": 0.4}},
        {"type": "text", "text": "{{collab_title}}",                          "effect": "zoom_in",  "position": "center", "color": "{{accent_color}}", "timing": {"start": 0.9}},
        {"type": "text", "text": "{{event_date}}",                            "effect": "slide_up", "position": "bottom", "color": "#aaaaaa",          "timing": {"start": 1.4}}
      ]
    }
  ],
  "transitions": {"default": {"type": "dissolve_ii", "duration": 0.5}}
}
