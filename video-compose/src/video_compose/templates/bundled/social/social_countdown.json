{
  "tvcs": "1.0",
  "template": {
    "id": "social_countdown",
    "name": "Social Countdown Teaser",
    "category": "social",
    "tags": [
      "countdown",
      "teaser",
      "launch",
      "social",
      "event"
    ],
    "description": "Build anticipation with a countdown teaser. Shows an event name, date, and a \"coming soon\" call-to-action.",
    "preview_thumbnail": "previews/thumbnails/social_countdown.jpg",
    "preview_full": "previews/full/social_countdown.jpg",
    "author": "Trollfabriken",
    "version": "1.0",
    "variables": [
      {
        "name": "event_name",
        "type": "string",
        "label": "Event / product name",
        "required": true,
        "default": "THE LAUNCH"
      },
      {
        "name": "date_text",
        "type": "string",
        "label": "Date / time text",
        "required": true,
        "default": "January 15, 2026"
      },
      {
        "name": "cta",
        "type": "string",
        "label": "Call to action",
        "required": false,
        "default": "Mark your calendar"
      },
      {
        "name": "bg_color",
        "type": "color",
        "label": "Background colour",
        "required": false,
        "default": "#0a0020"
      },
      {
        "name": "accent_color",
        "type": "color",
        "label": "Accent colour",
        "required": false,
        "default": "#8800ff"
      },
      {
        "name": "clip_duration",
        "type": "duration",
        "label": "Duration (seconds)",
        "required": false,
        "default": 7.0
      }
    ]
  },
  "output": {
    "width": 1080,
    "height": 1080,
    "fps": 30,
    "path": "./output/social_countdown.mp4"
  },
  "theme": {
    "background": "{{bg_color}}",
    "text_color": "#ffffff"
  },
  "segments": [
    {
      "id": "teaser",
      "type": "blank",
      "duration": "{{clip_duration}}",
      "color": "{{bg_color}}",
      "bg_style": "gradient_d",
      "overlays": [
        {
          "type": "text",
          "text": "{{event_name}}",
          "effect": "impact_slam",
          "position": "center",
          "color": "{{accent_color}}",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.4,
          "timing": {
            "start": 0.5
          }
        },
        {
          "type": "text",
          "text": "{{date_text}}",
          "effect": "punch_zoom_title",
          "position": "center",
          "color": "#ffffff",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.2,
          "timing": {
            "start": 1.5
          }
        },
        {
          "type": "text",
          "text": "{{cta}}",
          "effect": "kinetic_pop",
          "position": "bottom",
          "color": "{{accent_color}}",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.0,
          "timing": {
            "start": 3.0
          }
        }
      ]
    }
  ]
}
