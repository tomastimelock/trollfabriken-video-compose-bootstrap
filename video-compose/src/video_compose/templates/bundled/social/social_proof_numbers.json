{
  "tvcs": "1.0",
  "template": {
    "id": "social_proof_numbers",
    "name": "Social Proof — Big Numbers",
    "category": "social",
    "tags": [
      "social-proof",
      "statistics",
      "numbers",
      "impact",
      "marketing",
      "data",
      "social",
      "dark"
    ],
    "description": "High-impact social proof card: punchy headline intro on a radial dark background, followed by three big statistics with punch-zoom numbers and staggered label reveals. Ideal for marketing and brand credibility posts.",
    "preview_thumbnail": "previews/thumbnails/social_proof_numbers.jpg",
    "preview_full": "previews/full/social_proof_numbers.jpg",
    "author": "Trollfabriken",
    "version": "1.0",
    "variables": [
      {
        "name": "headline",
        "type": "string",
        "label": "Intro headline",
        "required": false,
        "default": "The Numbers Don't Lie"
      },
      {
        "name": "stat_1",
        "type": "string",
        "label": "Statistic 1",
        "required": true,
        "default": "10M+"
      },
      {
        "name": "label_1",
        "type": "string",
        "label": "Label for stat 1",
        "required": true,
        "default": "Active Users"
      },
      {
        "name": "stat_2",
        "type": "string",
        "label": "Statistic 2",
        "required": true,
        "default": "98%"
      },
      {
        "name": "label_2",
        "type": "string",
        "label": "Label for stat 2",
        "required": true,
        "default": "Satisfaction Rate"
      },
      {
        "name": "stat_3",
        "type": "string",
        "label": "Statistic 3",
        "required": true,
        "default": "$2B"
      },
      {
        "name": "label_3",
        "type": "string",
        "label": "Label for stat 3",
        "required": true,
        "default": "Revenue Generated"
      },
      {
        "name": "accent_color",
        "type": "color",
        "label": "Accent colour",
        "required": false,
        "default": "#22d3ee"
      }
    ]
  },
  "output": {
    "width": 1280,
    "height": 720,
    "fps": 30,
    "formats": ["mp4"],
    "path": "./output/video.mp4",
    "quality": 22
  },
  "theme": {
    "background": "#050505",
    "text_color": "#ffffff"
  },
  "segments": [
    {
      "id": "intro_flash",
      "type": "blank",
      "duration": 3.0,
      "color": "#050505",
      "bg_style": "radial",
      "overlays": [
        {
          "type": "text",
          "text": "{{headline}}",
          "effect": "impact_slam",
          "position": "center",
          "color": "#ffffff",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 2.0,
          "timing": {
            "start": 0.3,
            "end": 3.0
          }
        }
      ]
    },
    {
      "id": "stats_card",
      "type": "blank",
      "duration": 7.0,
      "color": "#050505",
      "bg_style": "gradient_v_dark",
      "overlays": [
        {
          "type": "text",
          "text": "{{stat_1}}",
          "effect": "punch_zoom_title",
          "position": "top-left",
          "color": "{{accent_color}}",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 2.0,
          "timing": {
            "start": 0.3,
            "end": 7.0
          }
        },
        {
          "type": "text",
          "text": "{{label_1}}",
          "effect": "fade_in",
          "position": "bottom-left",
          "color": "#ffffff",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 0.8,
          "timing": {
            "start": 0.8,
            "end": 7.0
          }
        },
        {
          "type": "text",
          "text": "{{stat_2}}",
          "effect": "punch_zoom_title",
          "position": "center",
          "color": "{{accent_color}}",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 2.0,
          "timing": {
            "start": 0.6,
            "end": 7.0
          }
        },
        {
          "type": "text",
          "text": "{{label_2}}",
          "effect": "fade_in",
          "position": "bottom",
          "color": "#ffffff",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 0.8,
          "timing": {
            "start": 1.1,
            "end": 7.0
          }
        },
        {
          "type": "text",
          "text": "{{stat_3}}",
          "effect": "punch_zoom_title",
          "position": "top-right",
          "color": "{{accent_color}}",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 2.0,
          "timing": {
            "start": 0.9,
            "end": 7.0
          }
        },
        {
          "type": "text",
          "text": "{{label_3}}",
          "effect": "fade_in",
          "position": "bottom-right",
          "color": "#ffffff",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 0.8,
          "timing": {
            "start": 1.4,
            "end": 7.0
          }
        }
      ]
    }
  ],
  "transitions": {
    "default": {
      "type": "dissolve_ii",
      "duration": 0.5
    },
    "overrides": []
  }
}
