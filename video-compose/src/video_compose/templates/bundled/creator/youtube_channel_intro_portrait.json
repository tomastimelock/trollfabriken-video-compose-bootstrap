{
  "tvcs": "1.0",
  "template": {
    "id": "youtube_channel_intro_portrait",
    "name": "YouTube Channel Intro (Portrait 9:16)",
    "category": "creator",
    "tags": [
      "subscribe",
      "reels",
      "portrait",
      "creator",
      "youtube",
      "channel",
      "9:16",
      "logo",
      "branding",
      "stories",
      "vertical",
      "intro"
    ],
    "description": "YouTube channel intro bumper: animated particle / shape effect with channel name, subscribe CTA, short stinger. Designed for 5-10 second channel branding. Adapted for vertical (9:16) video — Instagram Reels, TikTok, YouTube Shorts.",
    "preview_thumbnail": "previews/thumbnails/youtube_channel_intro.jpg",
    "preview_full": "previews/full/youtube_channel_intro.jpg",
    "author": "Trollfabriken",
    "version": "1.0",
    "variables": [
      {
        "name": "channel_name",
        "type": "string",
        "label": "Channel name",
        "required": true,
        "default": "TechWithTomas"
      },
      {
        "name": "tagline",
        "type": "string",
        "label": "Channel tagline",
        "required": false,
        "default": "Code, AI, and Curiosity"
      },
      {
        "name": "cta",
        "type": "string",
        "label": "CTA text",
        "required": false,
        "default": "Subscribe for weekly videos"
      },
      {
        "name": "shape_effect",
        "type": "string",
        "label": "Background FX",
        "required": false,
        "default": "neon_glow_shape",
        "choices": [
          "neon_glow_shape",
          "particle_flow",
          "constellation",
          "hexgrid"
        ]
      },
      {
        "name": "accent_color",
        "type": "color",
        "label": "Primary channel colour",
        "required": false,
        "default": "#ff0000"
      },
      {
        "name": "secondary_color",
        "type": "color",
        "label": "Secondary colour",
        "required": false,
        "default": "#ffffff"
      },
      {
        "name": "bg_color",
        "type": "color",
        "label": "Background colour",
        "required": false,
        "default": "#0a0a0a"
      },
      {
        "name": "duration",
        "type": "duration",
        "label": "Total duration (s)",
        "required": false,
        "default": 7.0
      }
    ]
  },
  "output": {
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "path": "./output/youtube_channel_intro.mp4"
  },
  "theme": {
    "background": "{{bg_color}}",
    "text_color": "#ffffff"
  },
  "segments": [
    {
      "id": "intro",
      "type": "shape",
      "duration": "{{duration}}",
      "effect": "{{shape_effect}}",
      "config": {
        "color": "{{accent_color}}"
      },
      "overlays": [
        {
          "type": "text",
          "text": "{{channel_name}}",
          "effect": "impact_slam",
          "position": "center",
          "color": "{{secondary_color}}",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.4,
          "timing": {
            "start": 0.8
          },
          "stroke_color": "#000000",
          "stroke_width": 1
        },
        {
          "type": "text",
          "text": "{{tagline}}",
          "effect": "spring_words",
          "position": "bottom",
          "color": "{{accent_color}}",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.0,
          "timing": {
            "start": 1.3
          }
        },
        {
          "type": "text",
          "text": "{{cta}}",
          "effect": "spring_words",
          "position": "bottom",
          "color": "#aaaaaa",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.0,
          "timing": {
            "start": 3.5
          }
        }
      ]
    }
  ]
}