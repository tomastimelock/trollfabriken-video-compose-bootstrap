{
  "tvcs": "1.0",
  "template": {
    "id": "company_logo_reveal",
    "name": "Company Logo Reveal",
    "category": "brand",
    "tags": [
      "brand",
      "logo",
      "reveal",
      "corporate",
      "minimal",
      "dark",
      "premium"
    ],
    "description": "Premium minimal dark logo reveal: neon-glow tagline teaser, dramatic punch-zoom company name reveal on a radial-lit card, and a clean brand hold with CTA. Ideal for corporate idents and brand openers.",
    "preview_thumbnail": "previews/thumbnails/company_logo_reveal.jpg",
    "preview_full": "previews/full/company_logo_reveal.jpg",
    "author": "Trollfabriken",
    "version": "1.0",
    "variables": [
      {
        "name": "company_name",
        "type": "string",
        "label": "Company name",
        "required": true
      },
      {
        "name": "tagline",
        "type": "string",
        "label": "Brand tagline",
        "required": true
      },
      {
        "name": "cta_text",
        "type": "string",
        "label": "Call-to-action text",
        "required": false,
        "default": "Building the future"
      },
      {
        "name": "accent_color",
        "type": "color",
        "label": "Accent colour",
        "required": false,
        "default": "#f59e0b"
      }
    ]
  },
  "output": {
    "width": 1280,
    "height": 720,
    "fps": 30,
    "formats": ["mp4"],
    "path": "./output/video.mp4",
    "quality": 22
  },
  "theme": {
    "background": "#050505",
    "text_color": "#ffffff"
  },
  "segments": [
    {
      "id": "suspense_build",
      "type": "blank",
      "duration": 3.0,
      "color": "#050505",
      "bg_style": "solid",
      "overlays": [
        {
          "type": "text",
          "text": "{{tagline}}",
          "effect": "neon_glow_text",
          "position": "center",
          "color": "{{accent_color}}",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.2,
          "timing": {
            "start": 0.5
          }
        }
      ]
    },
    {
      "id": "logo_reveal",
      "type": "blank",
      "duration": 4.0,
      "color": "#0a0a0a",
      "bg_style": "radial",
      "overlays": [
        {
          "type": "text",
          "text": "{{company_name}}",
          "effect": "punch_zoom_title",
          "position": "center",
          "color": "#ffffff",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 2.0,
          "timing": {
            "start": 0.3
          }
        },
        {
          "type": "text",
          "text": "{{tagline}}",
          "effect": "word_reveal",
          "position": "lower_third",
          "color": "{{accent_color}}",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.0,
          "timing": {
            "start": 1.0
          }
        }
      ]
    },
    {
      "id": "brand_hold",
      "type": "blank",
      "duration": 3.0,
      "color": "#050505",
      "bg_style": "solid",
      "overlays": [
        {
          "type": "text",
          "text": "{{cta_text}}",
          "effect": "fade_in",
          "position": "center",
          "color": "#ffffff",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.1,
          "timing": {
            "start": 0.5
          }
        }
      ]
    }
  ],
  "transitions": {
    "default": {
      "type": "dissolve_ii",
      "duration": 0.5
    },
    "overrides": []
  }
}
