{
  "tvcs": "1.0",
  "template": {
    "id": "data_candlestick",
    "name": "Candlestick Chart",
    "category": "data_story",
    "tags": [
      "data",
      "candlestick",
      "OHLC",
      "stock",
      "crypto",
      "finance",
      "trading",
      "price"
    ],
    "description": "OHLC candlestick chart for stock or crypto price action: title card with ticker + period, animated candlestick chart, key level annotation outro (support, resistance, trend).",
    "preview_thumbnail": "previews/thumbnails/data_candlestick.jpg",
    "preview_full": "previews/full/data_candlestick.jpg",
    "author": "Trollfabriken",
    "version": "1.0",
    "variables": [
      {
        "name": "ticker",
        "type": "string",
        "label": "Ticker symbol",
        "required": true,
        "default": "AAPL"
      },
      {
        "name": "period_label",
        "type": "string",
        "label": "Period label",
        "required": false,
        "default": "Jan–Jun 2025"
      },
      {
        "name": "chart_data",
        "type": "data_ref",
        "label": "Price data (date -> close price)",
        "required": true,
        "default": {
          "Jan W1": 245.8,
          "Jan W2": 249.4,
          "Jan W3": 251.7,
          "Jan W4": 240.2,
          "Feb W1": 244.0,
          "Feb W2": 248.9
        },
        "description": "Dict of period label to closing price"
      },
      {
        "name": "key_level",
        "type": "string",
        "label": "Key level / annotation",
        "required": false,
        "default": "Key support: $240"
      },
      {
        "name": "accent_color",
        "type": "color",
        "label": "Accent colour",
        "required": false,
        "default": "#22c55e"
      },
      {
        "name": "bg_color",
        "type": "color",
        "label": "Background colour",
        "required": false,
        "default": "#0a0a0a"
      }
    ]
  },
  "output": {
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "path": "./output/data_candlestick.mp4"
  },
  "theme": {
    "background": "{{bg_color}}",
    "text_color": "#ffffff"
  },
  "segments": [
    {
      "id": "title",
      "type": "blank",
      "duration": 2.5,
      "color": "{{bg_color}}",
      "overlays": [
        {
          "type": "text",
          "text": "{{ticker}}",
          "effect": "drop_in",
          "position": "center",
          "color": "#ffffff",
          "timing": {
            "start": 0.4
          }
        },
        {
          "type": "text",
          "text": "{{period_label}}",
          "effect": "fade_in",
          "position": "bottom",
          "color": "{{accent_color}}",
          "timing": {
            "start": 1.0
          }
        }
      ]
    },
    {
      "id": "chart",
      "type": "chart",
      "duration": 8.0,
      "chart_type": "line",
      "data": "{{chart_data}}",
      "config": {
        "color": "{{accent_color}}",
        "animate": true,
        "show_volume": true
      },
      "overlays": [
        {
          "type": "text",
          "text": "{{ticker}}  ·  {{period_label}}",
          "effect": "fade_in",
          "position": "top",
          "color": "{{accent_color}}",
          "timing": {
            "start": 0.5
          }
        }
      ]
    },
    {
      "id": "annotation",
      "type": "blank",
      "duration": 3.0,
      "color": "{{bg_color}}",
      "overlays": [
        {
          "type": "text",
          "text": "{{ticker}}",
          "effect": "fade_in",
          "position": "top",
          "color": "{{accent_color}}",
          "timing": {
            "start": 0.3
          }
        },
        {
          "type": "text",
          "text": "{{key_level}}",
          "effect": "drop_in",
          "position": "center",
          "color": "#ffffff",
          "timing": {
            "start": 0.7
          }
        }
      ]
    }
  ],
  "transitions": {
    "default": {
      "type": "dissolve_ii",
      "duration": 0.5
    }
  }
}