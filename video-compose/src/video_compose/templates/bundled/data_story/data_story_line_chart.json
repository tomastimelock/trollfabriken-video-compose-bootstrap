{
  "tvcs": "1.0",
  "template": {
    "id": "data_story_line_chart",
    "name": "Data Story — Line Chart",
    "category": "data_story",
    "tags": ["chart", "line", "trend", "data", "time-series", "report"],
    "description": "Clean trend story: title card, animated line chart, closing stat. Best for time-series data — sales over months, growth over quarters.",
    "preview_thumbnail": "previews/thumbnails/data_story_line_chart.jpg",
    "preview_full": "previews/full/data_story_line_chart.jpg",
    "author": "Trollfabriken",
    "version": "1.0",
    "variables": [
      {"name": "title",        "type": "string",   "label": "Chart title",       "required": true,  "default": "Growth Trend"},
      {"name": "chart_data",   "type": "data_ref", "label": "Chart data",        "required": true,
        "default": {"title": "Monthly Revenue", "x_categories": ["Jan","Feb","Mar","Apr","May","Jun"], "series": [{"name": "Revenue", "values": [80,95,88,120,135,142]}], "y_label": "MSEK"}},
      {"name": "key_stat",     "type": "string",   "label": "Key closing stat",  "required": false, "default": "+78% year-on-year"},
      {"name": "accent_color", "type": "color",    "label": "Accent colour",     "required": false, "default": "#00ccff"},
      {"name": "bg_color",     "type": "color",    "label": "Background colour", "required": false, "default": "#0a0a1e"}
    ]
  },
  "output": {"width": 1920, "height": 1080, "fps": 30, "path": "./output/data_story_line_chart.mp4"},
  "theme": {"background": "{{bg_color}}", "text_color": "#ffffff"},
  "segments": [
    {
      "id": "title_card",
      "type": "blank",
      "duration": 2.5,
      "color": "{{bg_color}}",
      "overlays": [
        {"type": "text", "text": "{{title}}", "effect": "fade_in", "position": "center", "color": "{{accent_color}}", "timing": {"start": 0.3}}
      ]
    },
    {
      "id": "chart",
      "type": "chart",
      "duration": 8.0,
      "chart_type": "line",
      "data": "{{chart_data}}",
      "config": {}
    },
    {
      "id": "stat_card",
      "type": "blank",
      "duration": 3.0,
      "color": "{{bg_color}}",
      "overlays": [
        {"type": "text", "text": "{{key_stat}}", "effect": "zoom_in", "position": "center", "color": "{{accent_color}}", "timing": {"start": 0.4}}
      ]
    }
  ],
  "transitions": {"default": {"type": "dissolve_ii", "duration": 0.5}}
}
