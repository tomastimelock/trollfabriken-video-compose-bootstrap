{
  "tvcs": "1.0",
  "template": {
    "id": "data_world_choropleth",
    "name": "World Map Choropleth",
    "category": "data_story",
    "tags": [
      "data",
      "world",
      "map",
      "choropleth",
      "global",
      "geomap",
      "journalism",
      "international"
    ],
    "description": "Global world choropleth map: title card, animated world map coloured by country-level data, summary card with key finding. Covers all UN member states via ISO 3166-1 alpha-2 codes.",
    "preview_thumbnail": "previews/thumbnails/data_world_choropleth.jpg",
    "preview_full": "previews/full/data_world_choropleth.jpg",
    "author": "Trollfabriken",
    "version": "1.0",
    "variables": [
      {
        "name": "map_title",
        "type": "string",
        "label": "Map title",
        "required": true,
        "default": "Global GDP per Capita 2024"
      },
      {
        "name": "map_data",
        "type": "data_ref",
        "label": "Country data (ISO2 -> float)",
        "required": true,
        "default": {
          "US": 0.95,
          "GB": 0.82,
          "DE": 0.8,
          "FR": 0.78,
          "JP": 0.77,
          "CN": 0.55,
          "BR": 0.42,
          "IN": 0.31,
          "NG": 0.18,
          "ET": 0.1,
          "SE": 0.84,
          "NO": 0.92,
          "AU": 0.86
        },
        "description": "Dict of ISO 3166-1 alpha-2 country code to normalised float (0.0-1.0) or raw value"
      },
      {
        "name": "palette",
        "type": "string",
        "label": "Colour palette",
        "required": false,
        "default": "YlOrRd",
        "choices": [
          "YlOrRd",
          "Blues",
          "Greens",
          "Purples",
          "RdBu",
          "viridis",
          "plasma"
        ]
      },
      {
        "name": "key_finding",
        "type": "string",
        "label": "Key finding text",
        "required": false,
        "default": "Scandinavia leads on GDP per capita"
      },
      {
        "name": "source_note",
        "type": "string",
        "label": "Data source",
        "required": false,
        "default": "Source: World Bank 2024"
      },
      {
        "name": "accent_color",
        "type": "color",
        "label": "Accent colour",
        "required": false,
        "default": "#e63946"
      },
      {
        "name": "bg_color",
        "type": "color",
        "label": "Background colour",
        "required": false,
        "default": "#0a1628"
      }
    ]
  },
  "output": {
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "path": "./output/data_world_choropleth.mp4"
  },
  "theme": {
    "background": "{{bg_color}}",
    "text_color": "#ffffff"
  },
  "segments": [
    {
      "id": "title",
      "type": "blank",
      "duration": 2.5,
      "color": "{{bg_color}}",
      "overlays": [
        {
          "type": "text",
          "text": "{{map_title}}",
          "effect": "fade_in",
          "position": "center",
          "color": "#ffffff",
          "timing": {
            "start": 0.5
          }
        }
      ]
    },
    {
      "id": "world_map",
      "type": "geomap",
      "duration": 9.0,
      "scope": "world",
      "view": "regions",
      "data": "{{map_data}}",
      "palette": "{{palette}}",
      "animation": "ken_burns_zoom",
      "overlays": [
        {
          "type": "text",
          "text": "{{map_title}}",
          "effect": "fade_in",
          "position": "top",
          "color": "#ffffff",
          "timing": {
            "start": 0.5
          }
        }
      ]
    },
    {
      "id": "summary",
      "type": "blank",
      "duration": 3.5,
      "color": "{{bg_color}}",
      "overlays": [
        {
          "type": "text",
          "text": "{{map_title}}",
          "effect": "fade_in",
          "position": "top",
          "color": "{{accent_color}}",
          "timing": {
            "start": 0.3
          }
        },
        {
          "type": "text",
          "text": "{{key_finding}}",
          "effect": "drop_in",
          "position": "center",
          "color": "#ffffff",
          "timing": {
            "start": 0.8
          }
        },
        {
          "type": "text",
          "text": "{{source_note}}",
          "effect": "fade_in",
          "position": "bottom",
          "color": "#aaaaaa",
          "timing": {
            "start": 1.5
          }
        }
      ]
    }
  ],
  "transitions": {
    "default": {
      "type": "dissolve_ii",
      "duration": 0.5
    }
  }
}