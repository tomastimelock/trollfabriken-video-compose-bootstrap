{
  "tvcs": "1.0",
  "template": {
    "id": "event_agenda",
    "name": "Event Agenda",
    "category": "event",
    "tags": [
      "event",
      "agenda",
      "schedule",
      "programme",
      "conference",
      "programme"
    ],
    "description": "Event agenda reveal: title card, sequential animated agenda items with time + session, closing card with venue/date details.",
    "preview_thumbnail": "previews/thumbnails/event_agenda.jpg",
    "preview_full": "previews/full/event_agenda.jpg",
    "author": "Trollfabriken",
    "version": "1.0",
    "variables": [
      {
        "name": "event_name",
        "type": "string",
        "label": "Event name",
        "required": true,
        "default": "Tech Summit 2025"
      },
      {
        "name": "event_date",
        "type": "string",
        "label": "Event date",
        "required": true,
        "default": "15 September 2025"
      },
      {
        "name": "event_venue",
        "type": "string",
        "label": "Venue",
        "required": false,
        "default": "Stockholm Waterfront Congress Centre"
      },
      {
        "name": "item_1_time",
        "type": "string",
        "label": "Item 1 time",
        "required": false,
        "default": "09:00"
      },
      {
        "name": "item_1_title",
        "type": "string",
        "label": "Item 1 title",
        "required": false,
        "default": "Registration & Coffee"
      },
      {
        "name": "item_2_time",
        "type": "string",
        "label": "Item 2 time",
        "required": false,
        "default": "10:00"
      },
      {
        "name": "item_2_title",
        "type": "string",
        "label": "Item 2 title",
        "required": false,
        "default": "Opening Keynote"
      },
      {
        "name": "item_3_time",
        "type": "string",
        "label": "Item 3 time",
        "required": false,
        "default": "11:30"
      },
      {
        "name": "item_3_title",
        "type": "string",
        "label": "Item 3 title",
        "required": false,
        "default": "Panel: The Future of Work"
      },
      {
        "name": "item_4_time",
        "type": "string",
        "label": "Item 4 time",
        "required": false,
        "default": "13:00"
      },
      {
        "name": "item_4_title",
        "type": "string",
        "label": "Item 4 title",
        "required": false,
        "default": "Lunch & Networking"
      },
      {
        "name": "accent_color",
        "type": "color",
        "label": "Brand colour",
        "required": false,
        "default": "#e63946"
      },
      {
        "name": "bg_color",
        "type": "color",
        "label": "Background colour",
        "required": false,
        "default": "#0a1628"
      }
    ]
  },
  "output": {
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "path": "./output/event_agenda.mp4"
  },
  "theme": {
    "background": "{{bg_color}}",
    "text_color": "#ffffff"
  },
  "segments": [
    {
      "id": "title",
      "type": "blank",
      "duration": 2.5,
      "color": "{{bg_color}}",
      "bg_style": "gradient_v_dark",
      "overlays": [
        {
          "type": "text",
          "text": "{{event_name}}",
          "effect": "drop_in",
          "position": "center",
          "color": "#ffffff",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.4,
          "timing": {
            "start": 0.5
          }
        },
        {
          "type": "text",
          "text": "{{event_date}}",
          "effect": "neon_glow_text",
          "position": "bottom",
          "color": "{{accent_color}}",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.0,
          "timing": {
            "start": 1.2
          }
        }
      ]
    },
    {
      "id": "agenda",
      "type": "blank",
      "duration": 10.0,
      "color": "{{bg_color}}",
      "bg_style": "gradient_v_dark",
      "overlays": [
        {
          "type": "text",
          "text": "Programme",
          "effect": "slide_up_text",
          "position": "top",
          "color": "{{accent_color}}",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.0,
          "timing": {
            "start": 0.3
          }
        },
        {
          "type": "text",
          "text": "{{item_1_time}}  {{item_1_title}}",
          "effect": "slide_right_text",
          "position": "center",
          "color": "#ffffff",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.0,
          "timing": {
            "start": 0.8,
            "end": 3.5
          }
        },
        {
          "type": "text",
          "text": "{{item_2_time}}  {{item_2_title}}",
          "effect": "slide_right_text",
          "position": "center",
          "color": "#ffffff",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.0,
          "timing": {
            "start": 2.5,
            "end": 5.5
          }
        },
        {
          "type": "text",
          "text": "{{item_3_time}}  {{item_3_title}}",
          "effect": "slide_right_text",
          "position": "center",
          "color": "#ffffff",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.0,
          "timing": {
            "start": 4.5,
            "end": 7.5
          }
        },
        {
          "type": "text",
          "text": "{{item_4_time}}  {{item_4_title}}",
          "effect": "slide_right_text",
          "position": "center",
          "color": "#ffffff",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.0,
          "timing": {
            "start": 6.5
          }
        }
      ]
    },
    {
      "id": "venue",
      "type": "blank",
      "duration": 3.0,
      "color": "{{bg_color}}",
      "bg_style": "gradient_v_dark",
      "overlays": [
        {
          "type": "text",
          "text": "{{event_name}}",
          "effect": "fade_in",
          "position": "top",
          "color": "{{accent_color}}",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.0,
          "timing": {
            "start": 0.3
          }
        },
        {
          "type": "text",
          "text": "{{event_venue}}",
          "effect": "drop_in",
          "position": "center",
          "color": "#ffffff",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.2,
          "timing": {
            "start": 0.7
          }
        },
        {
          "type": "text",
          "text": "{{event_date}}",
          "effect": "slide_up_text",
          "position": "bottom",
          "color": "#cccccc",
          "font_family": "Inter",
          "shadow": true,
          "intensity": 1.0,
          "timing": {
            "start": 1.2
          }
        }
      ]
    }
  ],
  "transitions": {
    "default": {
      "type": "dissolve_ii",
      "duration": 0.5
    }
  }
}
